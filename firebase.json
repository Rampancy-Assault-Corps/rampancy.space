{
  "firestore": {
    "rules": "config/firestore.rules",
    "indexes": "config/firestore.indexes.json"
  },
  "storage": {
    "rules": "config/storage.rules"
  },
  "hosting": {
    "target": "release",
    "public": "rampancy_assault_corps_web/build/jaspr",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/auth/**",
        "run": {
          "serviceId": "rampancy-assault-corps-server",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "rampancy-assault-corps-server",
          "region": "us-central1"
        }
      },
      {
        "source": "/keepAlive",
        "run": {
          "serviceId": "rampancy-assault-corps-server",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}

ENABLE_ACCOUNT_LINKING=true
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:8080/auth/discord/callback
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=

OAUTH_STATE_SIGNING_KEY_BASE64=
TOKEN_ENCRYPTION_KEY_BASE64=
RAC_SESSION_MAX_AGE_SECONDS=86400
RAC_OAUTH_STATE_MAX_AGE_SECONDS=600
RAC_GATEWAY_HOST=127.0.0.1
RAC_GATEWAY_PORT=8080
RAC_BACKEND_PORT=8081
RAC_FRONTEND_PORT=8082
